# ── Required ────────────────────────────────────────────────────
DATABASE_URL=postgresql://payroll:payroll_secret@localhost:5432/payrolldb
JWT_SECRET=CHANGE_THIS_TO_A_RANDOM_64_CHAR_HEX_STRING

# Generate with:  openssl rand -hex 32

# ── Strongly recommended ────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0
SSN_ENCRYPTION_KEY=CHANGE_THIS_TO_A_RANDOM_32_CHAR_STRING

# Generate with:  openssl rand -hex 24

# ── Application ─────────────────────────────────────────────────
APP_ENV=development          # development | production
LOG_FORMAT=text              # text | json (json for Datadog/CloudWatch)
LOG_LEVEL=INFO
CORS_ORIGINS=http://localhost:3000

# ── File storage ────────────────────────────────────────────────
PAYSTUB_DIR=./paystubs
DOC_STORAGE_PATH=./documents

# ── Email (optional — paystubs + payroll summaries) ─────────────
# SMTP_HOST=smtp.sendgrid.net
# SMTP_PORT=587
# SMTP_USER=apikey
# SMTP_PASSWORD=your-sendgrid-api-key
# FROM_EMAIL=payroll@yourcompany.com

# ── JWT settings ─────────────────────────────────────────────────
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=480       # 8 hours
