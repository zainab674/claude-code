#!/usr/bin/env python3
"""
PayrollOS CLI — manage your payroll system from the terminal.

Usage:
    payrollos login
    payrollos employees list
    payrollos employees add
    payrollos payroll preview --period-start 2026-03-01 --period-end 2026-03-15
    payrollos payroll run     --period-start 2026-03-01 --period-end 2026-03-15
    payrollos payroll history
    payrollos paystubs list
    payrollos paystubs download <paystub-id>
    payrollos reports ytd
    payrollos reports tax-liability
    payrollos pto requests
    payrollos export employees
    payrollos export ytd
    payrollos health

Install:
    pip install click requests tabulate
    chmod +x cli/payrollos
    ln -s $(pwd)/cli/payrollos /usr/local/bin/payrollos
"""
import os
import sys
import json
import configparser
from pathlib import Path

try:
    import click
    import requests
    from tabulate import tabulate
except ImportError:
    print("Install dependencies: pip install click requests tabulate")
    sys.exit(1)

CONFIG_DIR = Path.home() / ".payrollos"
CONFIG_FILE = CONFIG_DIR / "config.ini"
TOKEN_FILE = CONFIG_DIR / "token"

DEFAULT_API = os.getenv("PAYROLLOS_API_URL", "http://localhost:8000")


# ── Config helpers ─────────────────────────────────────────────
def get_config():
    cfg = configparser.ConfigParser()
    if CONFIG_FILE.exists():
        cfg.read(CONFIG_FILE)
    return cfg


def get_token():
    if TOKEN_FILE.exists():
        return TOKEN_FILE.read_text().strip()
    return os.getenv("PAYROLLOS_TOKEN", "")


def save_token(token: str):
    CONFIG_DIR.mkdir(exist_ok=True)
    TOKEN_FILE.write_text(token)
    TOKEN_FILE.chmod(0o600)


def get_api_url():
    cfg = get_config()
    return cfg.get("api", "url", fallback=DEFAULT_API)


def api(method: str, path: str, json_data=None, params=None, stream=False):
    url = f"{get_api_url()}{path}"
    token = get_token()
    headers = {"Authorization": f"Bearer {token}"} if token else {}
    resp = requests.request(method, url, json=json_data, params=params,
                            headers=headers, stream=stream, timeout=30)
    if resp.status_code == 401:
        click.echo("❌ Not authenticated. Run: payrollos login", err=True)
        sys.exit(1)
    if resp.status_code >= 400 and not stream:
        try:
            detail = resp.json().get("detail", resp.text)
        except Exception:
            detail = resp.text
        click.echo(f"❌ Error {resp.status_code}: {detail}", err=True)
        sys.exit(1)
    return resp


def fmt_money(n):
    return f"${float(n or 0):>12,.2f}"


def fmt_table(rows, headers):
    click.echo(tabulate(rows, headers=headers, tablefmt="rounded_outline"))


# ── CLI root ───────────────────────────────────────────────────
@click.group()
@click.version_option("1.0.0", prog_name="payrollos")
def cli():
    """PayrollOS command-line interface."""
    pass


# ── Login ──────────────────────────────────────────────────────
@cli.command()
@click.option("--url", default=None, help="API base URL")
def login(url):
    """Authenticate and save credentials."""
    if url:
        CONFIG_DIR.mkdir(exist_ok=True)
        cfg = get_config()
        if "api" not in cfg:
            cfg["api"] = {}
        cfg["api"]["url"] = url
        with open(CONFIG_FILE, "w") as f:
            cfg.write(f)

    email = click.prompt("Email")
    password = click.prompt("Password", hide_input=True)

    try:
        resp = requests.post(
            f"{get_api_url()}/auth/login",
            json={"email": email, "password": password},
            timeout=10,
        )
        if resp.status_code != 200:
            click.echo(f"❌ Login failed: {resp.json().get('detail', 'Unknown error')}")
            sys.exit(1)
        data = resp.json()
        save_token(data["access_token"])
        user = data["user"]
        click.echo(f"✅ Logged in as {user['email']} ({user['role']})")
    except requests.exceptions.ConnectionError:
        click.echo(f"❌ Cannot connect to {get_api_url()}")
        sys.exit(1)


@cli.command()
def logout():
    """Remove saved credentials."""
    if TOKEN_FILE.exists():
        TOKEN_FILE.unlink()
    click.echo("✅ Logged out")


# ── Employees ──────────────────────────────────────────────────
@cli.group()
def employees():
    """Manage employees."""
    pass


@employees.command("list")
@click.option("--status", default="active", help="Filter by status")
@click.option("--search", default="", help="Search by name/email")
@click.option("--json", "as_json", is_flag=True, help="Output as JSON")
def employees_list(status, search, as_json):
    """List all employees."""
    params = {}
    if status:
        params["status"] = status
    if search:
        params["search"] = search
    data = api("GET", "/employees", params=params).json()
    emps = data.get("employees", [])

    if as_json:
        click.echo(json.dumps(emps, indent=2))
        return

    click.echo(f"\n  {len(emps)} employees ({status})\n")
    rows = [
        (
            e["full_name"],
            e.get("job_title", ""),
            e.get("department", ""),
            e["pay_type"],
            fmt_money(e["pay_rate"]),
            e["status"],
        )
        for e in emps
    ]
    fmt_table(rows, ["Name", "Title", "Department", "Pay type", "Rate", "Status"])


@employees.command("show")
@click.argument("employee_id")
def employees_show(employee_id):
    """Show employee details."""
    emp = api("GET", f"/employees/{employee_id}").json()
    for k, v in emp.items():
        if v is not None:
            click.echo(f"  {k:<35} {v}")


@employees.command("add")
def employees_add():
    """Interactively add a new employee."""
    click.echo("\n  Add new employee\n")
    data = {
        "first_name": click.prompt("  First name"),
        "last_name": click.prompt("  Last name"),
        "email": click.prompt("  Email", default=""),
        "hire_date": click.prompt("  Hire date (YYYY-MM-DD)"),
        "pay_type": click.prompt("  Pay type", default="salary",
                                  type=click.Choice(["salary", "hourly", "contract"])),
        "pay_rate": float(click.prompt("  Pay rate (annual salary or hourly rate)")),
        "department": click.prompt("  Department", default=""),
        "job_title": click.prompt("  Job title", default=""),
        "state_code": click.prompt("  State", default="NY"),
        "filing_status": click.prompt("  Filing status", default="single",
                                       type=click.Choice(["single", "married", "head_of_household"])),
    }
    emp = api("POST", "/employees", json_data=data).json()
    click.echo(f"\n  ✅ Created {emp['full_name']} (ID: {emp['id'][:8]}…)")


# ── Payroll ────────────────────────────────────────────────────
@cli.group()
def payroll():
    """Run and manage payroll."""
    pass


@payroll.command("preview")
@click.option("--period-start", required=True, help="YYYY-MM-DD")
@click.option("--period-end", required=True, help="YYYY-MM-DD")
def payroll_preview(period_start, period_end):
    """Preview payroll for a pay period."""
    data = api("POST", "/payroll/preview", json_data={
        "period_start": period_start,
        "period_end": period_end,
    }).json()

    click.echo(f"\n  Payroll preview  {period_start} – {period_end}\n")
    t = data["totals"]
    click.echo(f"  Employees:    {data['employee_count']}")
    click.echo(f"  Gross:       {fmt_money(t['gross'])}")
    click.echo(f"  Emp taxes:   {fmt_money(t['employee_taxes'])}")
    click.echo(f"  Deductions:  {fmt_money(t['deductions'])}")
    click.echo(f"  Net pay:     {fmt_money(t['net'])}")

    click.echo()
    rows = [
        (
            item["employee_name"],
            fmt_money(item["gross_pay"]),
            fmt_money(item["total_employee_taxes"]),
            fmt_money(item["net_pay"]),
        )
        for item in data.get("items", [])
    ]
    fmt_table(rows, ["Employee", "Gross", "Taxes", "Net"])


@payroll.command("run")
@click.option("--period-start", required=True, help="YYYY-MM-DD")
@click.option("--period-end", required=True, help="YYYY-MM-DD")
@click.option("--pay-date", default=None, help="YYYY-MM-DD (defaults to period-end + 5 days)")
@click.option("--yes", is_flag=True, help="Skip confirmation prompt")
def payroll_run(period_start, period_end, pay_date, yes):
    """Run payroll for a pay period."""
    if not yes:
        click.confirm(f"  Run payroll for {period_start} – {period_end}?", abort=True)

    click.echo("  Running payroll…")
    payload = {"period_start": period_start, "period_end": period_end}
    if pay_date:
        payload["pay_date"] = pay_date

    data = api("POST", "/payroll/run", json_data=payload).json()
    click.echo(f"\n  ✅ Payroll complete!")
    click.echo(f"  Pay run ID:  {data['pay_run_id'][:8]}…")
    click.echo(f"  Employees:   {data['employee_count']}")
    t = data["totals"]
    click.echo(f"  Gross:      {fmt_money(t['gross'])}")
    click.echo(f"  Net paid:   {fmt_money(t['net'])}")
    click.echo(f"  Emp taxes:  {fmt_money(t['employee_taxes'])}")
    click.echo(f"  Er taxes:   {fmt_money(t['employer_taxes'])}")


