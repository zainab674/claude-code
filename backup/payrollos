# ── Calculator ─────────────────────────────────────────────────
@cli.command()
@click.option("--salary", default=None, type=float, help="Annual salary")
@click.option("--hourly", default=None, type=float, help="Hourly rate")
@click.option("--state", default="NY", help="State code")
@click.option("--filing", default="single",
              type=click.Choice(["single", "married", "head_of_household"]))
@click.option("--frequency", default="biweekly",
              type=click.Choice(["weekly", "biweekly", "semimonthly", "monthly"]))
def calculate(salary, hourly, state, filing, frequency):
    """Calculate net paycheck."""
    if not salary and not hourly:
        click.echo("Provide --salary or --hourly")
        sys.exit(1)

    payload = {
        "pay_type": "salary" if salary else "hourly",
        "annual_salary": salary,
        "hourly_rate": hourly,
        "state_code": state,
        "filing_status": filing,
        "pay_frequency": frequency,
    }
    data = api("POST", "/payroll/calculate", json_data=payload).json()

    click.echo(f"\n  Paycheck calculator  [{frequency} · {filing} · {state}]\n")
    click.echo(f"  Gross pay:        {fmt_money(data['gross_pay'])}")
    click.echo(f"  Pre-tax deductions{fmt_money(data['pretax_deductions'])}")
    click.echo(f"  Federal tax:      {fmt_money(data['federal_income_tax'])}  ({data['effective_federal_rate']}%)")
    click.echo(f"  State tax:        {fmt_money(data['state_income_tax'])}  ({data['effective_state_rate']}%)")
    click.echo(f"  Social security:  {fmt_money(data['social_security_tax'])}")
    click.echo(f"  Medicare:         {fmt_money(data['medicare_tax'])}")
    click.echo(f"  ─────────────────────────────────")
    click.echo(f"  Net pay:          {fmt_money(data['net_pay'])}")
    click.echo(f"\n  Employer true cost:{fmt_money(data['true_cost'])}")


if __name__ == "__main__":
    cli()
