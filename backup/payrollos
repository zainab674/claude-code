# ── Health ─────────────────────────────────────────────────────
@cli.command()
@click.option("--detailed", is_flag=True)
def health(detailed):
    """Check API health."""
    path = "/health/detailed" if detailed else "/health"
    try:
        data = api("GET", path).json()
    except SystemExit:
        click.echo("❌ API unreachable")
        return

    status_emoji = "✅" if data.get("status") in ("ok", "healthy", "ready") else "⚠️"
    click.echo(f"\n  {status_emoji} {data.get('service', 'PayrollOS')} — {data.get('status', 'unknown')}")

    if detailed:
        click.echo(f"  Version: {data.get('version')}")
        click.echo(f"  Uptime:  {data.get('uptime')}")
        for name, check in data.get("checks", {}).items():
            emoji = "✅" if check.get("status") == "ok" else "⚠️"
            details = ", ".join(f"{k}={v}" for k, v in check.items() if k != "status")
            click.echo(f"  {emoji} {name:<20} {details}")


# ── Export ─────────────────────────────────────────────────────
@cli.group()
def export():
    """Export data as CSV."""
    pass


@export.command("employees")
@click.option("--output", "-o", default="employees.csv")
def export_employees(output):
    """Export employee roster to CSV."""
    resp = api("GET", "/export/employees", stream=True)
    with open(output, "wb") as f:
        for chunk in resp.iter_content(chunk_size=8192):
            f.write(chunk)
    click.echo(f"✅ Saved to {output}")


@export.command("ytd")
@click.option("--year", default=None, type=int)
@click.option("--output", "-o", default=None)
def export_ytd(year, output):
    """Export YTD employee data to CSV."""
    year = year or __import__("datetime").date.today().year
    output = output or f"employee-ytd-{year}.csv"
    resp = api("GET", f"/export/employee-ytd?year={year}", stream=True)
    with open(output, "wb") as f:
        for chunk in resp.iter_content(chunk_size=8192):
            f.write(chunk)
    click.echo(f"✅ Saved to {output}")


